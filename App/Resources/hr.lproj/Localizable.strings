/* Sensitivity & Sensors Section */

/* Sensitivity & Sensors accordion title */
"section_sensitivity_sensors" = "Osjetljivost i senzori";

/* Sensor consensus setting title */
"setting_consensus" = "Konsenzus senzora";

/* Sensor consensus setting help text */
"help_consensus" = "Broj senzora koji moraju neovisno detektirati udarac prije okidanja. Ograničeno na broj senzora koji isporučuju podatke.";

/* Sensor consensus count */

/* Reactivity setting help text */
"help_reactivity" = "Prozor odgovora na silu udarca. Donji klizač = najslabija sila koja okida. Gornji klizač = sila za maksimalni odgovor. Više vrijednosti reagiraju na lakše uderce.";

/* Volume setting title */
"setting_volume" = "Glasnoća";

/* Volume setting help text */
"help_volume" = "Prozor razine reprodukcije zvuka. Intenzitet se linealno preslikava između niskog i visokog. Odabir isječka također prati intenzitet — lakši udari reproduciraju kraće isječke.";


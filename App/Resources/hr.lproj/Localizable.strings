/* Cooldown setting title */
"setting_cooldown" = "Hlađenje";

/* Cooldown setting help text */
"help_cooldown" = "Minimalno vrijeme između reakcija. 0 = ograničeno samo trajanjem isječka koji se reproducira.";

/* Accelerometer tuning section header */
"section_accel_tuning" = "Podešavanje akcelerometra";

/* Frequency band setting title */
"setting_frequency_band" = "Frekvencijski pojas";

/* Frequency band setting help text */
"help_frequency_band" = "Bandpass filtar na sirovim podacima akcelerometra. Nisko = visokopropusni odrez (odbija vibracije poda). Visoko = niskopropusni odrez (odbija elektronički šum).";

/* Spike threshold setting title */
"setting_spike_threshold" = "Prag skoka";

/* Spike threshold setting help text */
"help_spike_threshold" = "Minimalna filtrirana veličina (g-sila) za razmatranje kao potencijalnog udarca. Primjenjuje se nakon bandpass filtriranja. Više vrijednosti zahtijevaju veću silu.";

/* Crest factor setting title */
"setting_crest_factor" = "Crest Factor";

/* Crest factor setting help text */
"help_crest_factor" = "Vršni signal mora premašiti pozadinski RMS ovim višekratnikom. Oštri udari o stol skaču daleko iznad pozadine. Koraci podižu pozadinu zajedno s vrhom. Više vrijednosti odbijaju više okolnih vibracija.";

/* Rise rate setting title */
"setting_rise_rate" = "Rise Rate";

/* Rise rate setting help text */
"help_rise_rate" = "Minimalni porast veličine između uzastopnih uzoraka. Izravni udari rastu u 1-2 uzorka. Prenesene vibracije rastu postupno. Više vrijednosti odbijaju neizravne vibracije.";

/* Confirmations setting title */
"setting_confirmations" = "Potvrde";

/* Confirmations setting help text */
"help_confirmations" = "Uzorci iznad praga potrebni u prozoru detekcije od 120ms. Izravni udari proizvode 3-5 visokih uzoraka. Pojedinačni trzaji proizvode 1-2.";

/* Confirmation hit count */
"confirmations_format" = "%lld pogodaka";

/* Warmup setting title */
"setting_warmup" = "Zagrijavanje";

/* Warmup setting help text */
"help_warmup" = "Uzorci prije aktiviranja detekcije. Filtri trebaju vrijeme za stabilizaciju. Pri 50 Hz, 50 uzoraka = 1 sekunda.";

/* Report interval setting title */
"setting_report_interval" = "Interval izvješćivanja";

/* Report interval setting help text */
"help_report_interval" = "Interval prozivanja akcelerometra. 10ms = 100 Hz (zadano), 5ms = 200 Hz, 20ms = 50 Hz.";


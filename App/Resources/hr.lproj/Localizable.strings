"setting_flash_opacity" = "Neprozirnost bljeska";

/* Flash opacity setting help text */
"help_flash_opacity" = "Prozor svjetline bljeska zaslona. Vremenski ritam omotnice oblikovan je intenzitetom. Ograničen unutar trajanja zvučnog isječka.";


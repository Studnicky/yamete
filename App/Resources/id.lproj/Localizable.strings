/* Sensitivity & Sensors Section */

/* Sensitivity & Sensors accordion title */

/* Sensor consensus setting title */
"setting_consensus" = "Impact Consensus";

/* Sensor consensus setting help text */
"help_consensus" = "Number of impact sensors (accelerometer, microphone, AirPods motion) that must independently detect an impact before triggering. Clamped to the number of impact sensors delivering data. Does not apply to discrete-event sources (USB, lid, thermal, etc.).";

/* Sensor consensus count */
"consensus_format" = "%lld impact sensors";

/* Cooldown setting title */
"setting_cooldown" = "Jeda Pendinginan";

/* Cooldown setting help text */
"help_cooldown" = "Waktu minimum antara reaksi. 0 = hanya dibatasi oleh durasi klip yang diputar.";

/* Accelerometer tuning section header */
"section_accel_tuning" = "Penyetelan Akselerometer";

/* Frequency band setting title */
"setting_frequency_band" = "Pita Frekuensi";

/* Frequency band setting help text */
"help_frequency_band" = "Filter bandpass pada data akselerometer mentah. Rendah = cutoff high-pass (menolak getaran lantai). Tinggi = cutoff low-pass (menolak kebisingan elektronik).";

/* Spike threshold setting title */
"setting_spike_threshold" = "Ambang Lonjakan";

/* Spike threshold setting help text */
"help_spike_threshold" = "Magnitudo terfilter minimum (g-force) untuk dianggap sebagai benturan potensial. Diterapkan setelah penyaringan bandpass. Nilai lebih tinggi membutuhkan gaya lebih kuat.";

/* Crest factor setting title */
"setting_crest_factor" = "Faktor Puncak";

/* Crest factor setting help text */
"help_crest_factor" = "Sinyal puncak harus melebihi RMS latar belakang dengan kelipatan ini. Benturan meja tajam melonjak jauh di atas latar belakang. Langkah kaki meningkatkan latar belakang bersama puncaknya. Nilai lebih tinggi menolak lebih banyak getaran sekitar.";

/* Rise rate setting title */
"setting_rise_rate" = "Laju Naik";

/* Rise rate setting help text */
"help_rise_rate" = "Peningkatan magnitudo minimum antara sampel berurutan. Benturan langsung naik dalam 1-2 sampel. Getaran yang ditransmisikan naik secara bertahap. Nilai lebih tinggi menolak getaran tidak langsung.";

/* Confirmations setting title */
"setting_confirmations" = "Konfirmasi";

/* Confirmations setting help text */
"help_confirmations" = "Sampel di atas ambang yang diperlukan dalam jendela deteksi 120ms. Benturan langsung menghasilkan 3-5 sampel tinggi. Guncangan tunggal menghasilkan 1-2.";

/* Confirmation hit count */
"confirmations_format" = "%lld detakan";

/* Warmup setting title */
"setting_warmup" = "Pemanasan";

/* Warmup setting help text */
"help_warmup" = "Sampel sebelum deteksi aktif. Filter membutuhkan waktu untuk stabil. Pada 50 Hz, 50 sampel = 1 detik.";

/* Report interval setting title */
"setting_report_interval" = "Interval Laporan";

/* Report interval setting help text */
"help_report_interval" = "Interval polling akselerometer. 10ms = 100 Hz (default), 5ms = 200 Hz, 20ms = 50 Hz.";


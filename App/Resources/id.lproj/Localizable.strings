"setting_volume" = "Volume";

/* Volume setting help text */
"help_volume" = "Jendela tingkat pemutaran audio. Intensitas dipetakan secara linier antara rendah dan tinggi. Pemilihan klip juga mengikuti intensitas — benturan lebih ringan memainkan klip lebih pendek.";


"tier_tap_full" = "Atingere";

/* Impact tier name: light */
"tier_light_full" = "Ușor";

/* Impact tier name: medium */
"tier_medium_full" = "Mediu";

/* Impact tier name: firm */
"tier_firm_full" = "Ferm";

/* Impact tier name: hardest */
"tier_hard_full" = "Puternic";


/* Frequency band setting help text */
"help_frequency_band" = "Kaistanpäästösuodatin kiihtyvyysanturin raakatiedoille. Matala = ylipäästökynnys (hylkää lattiatärinät). Korkea = alipäästökynnys (hylkää elektroniset kohina).";

/* Spike threshold setting title */
"setting_spike_threshold" = "Piikkynnys";

/* Spike threshold setting help text */
"help_spike_threshold" = "Vähimmäissuodatettu suuruus (g-voima) mahdollisena iskuna pidettäväksi. Käytetään kaistanpäästösuodatuksen jälkeen. Korkeammat arvot vaativat suurempaa voimaa.";

/* Crest factor setting title */
"setting_crest_factor" = "Crest Factor";

/* Crest factor setting help text */
"help_crest_factor" = "Huippusignaalin täytyy ylittää taustan RMS tällä kertoimella. Terävät pöytäiskut piikkiävät selvästi taustan yläpuolelle. Askeleet nostavat taustaa huipun mukana. Korkeammat arvot hylkäävät enemmän ympäristövibratioita.";

/* Rise rate setting title */
"setting_rise_rate" = "Rise Rate";

/* Rise rate setting help text */
"help_rise_rate" = "Vähimmäissuuruuden kasvu peräkkäisten näytteiden välillä. Suorat iskut nousevat 1-2 näytteessä. Välitetty tärinä nousee asteittain. Korkeammat arvot hylkäävät epäsuoran tärinän.";

/* Confirmations setting title */
"setting_confirmations" = "Vahvistukset";

/* Confirmations setting help text */
"help_confirmations" = "Kynnyksen ylittävät näytteet 120 ms havaitsemisikkunassa. Suorat iskut tuottavat 3-5 korkeaa näytettä. Yksittäiset nykäykset tuottavat 1-2.";

/* Confirmation hit count */

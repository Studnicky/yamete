/* Warmup setting title */
"setting_warmup" = "Lämmittelyaika";

/* Warmup setting help text */
"help_warmup" = "Näytteet ennen havaitsemisen aktivoitumista. Suodattimet tarvitsevat aikaa vakautumiseen. 50 Hz:llä 50 näytettä = 1 sekunti.";

/* Report interval setting title */
"setting_report_interval" = "Raportointiväli";

/* Report interval setting help text */
"help_report_interval" = "Kiihtyvyysanturin kyselyväli. 10 ms = 100 Hz (oletus), 5 ms = 200 Hz, 20 ms = 50 Hz.";


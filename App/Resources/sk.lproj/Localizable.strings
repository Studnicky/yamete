/* Basic Settings Section */

/* Reactivity setting title */
"setting_reactivity" = "Reaktivita";

/* Reactivity setting help text */
"help_reactivity" = "Okno odozvy na silu nárazu. Dolný posúvač = najslabšia sila, ktorá spustí reakciu. Horný posúvač = sila pre maximálnu odozvu. Vyššie hodnoty reagujú na slabšie nárazy.";

/* Volume setting title */
"setting_volume" = "Hlasitosť";

/* Volume setting help text */
"help_volume" = "Okno úrovne prehrávania zvuku. Intenzita sa lineárne mapuje medzi minimom a maximom. Výber klipu tiež sleduje intenzitu — slabšie nárazy prehrávajú kratšie klipy.";

/* Flash opacity setting title */
"setting_flash_opacity" = "Nepriehľadnosť blesku";

/* Flash opacity setting help text */
"help_flash_opacity" = "Okno jasu blesku na obrazovke. Tvar obálky formovaný intenzitou. Ohraničené trvaním zvukového klipu.";


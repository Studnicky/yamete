"setting_confirmations" = "Bekreftelser";

/* Confirmations setting help text */
"help_confirmations" = "Prøver over terskel kreves i 120ms deteksjonsvinduet. Direkte treff produserer 3-5 høye prøver. Enkle støt produserer 1-2.";


"setting_crest_factor" = "Crest-faktor";

/* Crest factor setting help text */
"help_crest_factor" = "Toppignalet må overskride bakgrunns-RMS med dette flertallet. Skarpe skrivebordsstøt pigg godt over bakgrunnen. Fottrinn hever bakgrunnen sammen med toppen. Høyere verdier avviser mer omgivende vibrasjon.";

/* Rise rate setting title */
"setting_rise_rate" = "Stigningsrate";

/* Rise rate setting help text */
"help_rise_rate" = "Minimum magnitudeøkning mellom påfølgende prøver. Direkte støt stiger i 1-2 prøver. Overført vibrasjon stiger gradvis. Høyere verdier avviser indirekte vibrasjon.";


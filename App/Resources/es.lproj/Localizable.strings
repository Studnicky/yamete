/* Detection paused indicator */
"status_paused" = "En pausa";

/* Basic Settings Section */

/* Reactivity setting title */
"setting_reactivity" = "Reactividad";

/* Reactivity setting help text */
"help_reactivity" = "Ventana de respuesta a la fuerza de impacto. Pulgar bajo = fuerza mínima que activa. Pulgar alto = fuerza para respuesta máxima. Valores más altos responden a impactos más suaves.";

/* Volume setting title */
"setting_volume" = "Volumen";

/* Volume setting help text */
"help_volume" = "Ventana de nivel de reproducción de audio. La intensidad se mapea linealmente entre bajo y alto. La selección de clip también sigue la intensidad — los impactos más suaves reproducen clips más cortos.";

/* Flash opacity setting title */
"setting_flash_opacity" = "Opacidad del destello";

/* Flash opacity setting help text */
"help_flash_opacity" = "Ventana de brillo del destello de pantalla. El tiempo de la envolvente está modulado por la intensidad. Acotado dentro de la duración del clip de sonido.";

/* Sensitivity Ruler Labels */

/* Ruler label: hardest impact */
"tier_hard" = "Fuerte";

/* Ruler label: firm impact */
"tier_firm" = "Firme";

/* Ruler label: medium impact (abbreviated) */
"tier_medium" = "Med";

/* Ruler label: light impact */
"tier_light" = "Suave";

/* Ruler label: lightest impact */
"tier_tap" = "Toque";

/* Sensitivity & Sensors Section */

/* Sensitivity & Sensors accordion title */

/* Sensor consensus setting title */
"setting_consensus" = "Impact Consensus";

/* Sensor consensus setting help text */
"help_consensus" = "Number of impact sensors (accelerometer, microphone, AirPods motion) that must independently detect an impact before triggering. Clamped to the number of impact sensors delivering data. Does not apply to discrete-event sources (USB, lid, thermal, etc.).";

/* Sensor consensus count */
"consensus_format" = "%lld impact sensors";

/* Cooldown setting title */
"setting_cooldown" = "Enfriamiento";

/* Cooldown setting help text */
"help_cooldown" = "Tiempo mínimo entre reacciones. 0 = acotado solo por la duración del clip en reproducción.";

/* Accelerometer tuning section header */
"section_accel_tuning" = "Ajuste del Acelerómetro";

/* Frequency band setting title */
"setting_frequency_band" = "Banda de Frecuencia";

/* Frequency band setting help text */
"help_frequency_band" = "Filtro de paso de banda sobre los datos brutos del acelerómetro. Bajo = corte de paso alto (rechaza vibraciones del suelo). Alto = corte de paso bajo (rechaza ruido electrónico).";

/* Spike threshold setting title */
"setting_spike_threshold" = "Umbral de Pico";

/* Spike threshold setting help text */
"help_spike_threshold" = "Magnitud filtrada mínima (fuerza g) para considerar como impacto potencial. Se aplica tras el filtrado de paso de banda. Valores más altos requieren mayor fuerza.";

/* Crest factor setting title */
"setting_crest_factor" = "Factor de Cresta";

/* Crest factor setting help text */
"help_crest_factor" = "La señal de pico debe superar el RMS de fondo por este múltiplo. Los golpes bruscos en el escritorio superan ampliamente el fondo. Los pasos elevan el fondo junto con el pico. Valores más altos rechazan más vibraciones ambientales.";

/* Rise rate setting title */
"setting_rise_rate" = "Tasa de Subida";

/* Rise rate setting help text */
"help_rise_rate" = "Incremento mínimo de magnitud entre muestras consecutivas. Los impactos directos suben en 1-2 muestras. Las vibraciones transmitidas suben gradualmente. Valores más altos rechazan vibraciones indirectas.";

/* Confirmations setting title */
"setting_confirmations" = "Confirmaciones";

/* Confirmations setting help text */
"help_confirmations" = "Muestras por encima del umbral requeridas en la ventana de detección de 120 ms. Los golpes directos producen 3-5 muestras altas. Los sacudones simples producen 1-2.";

/* Confirmation hit count */
"confirmations_format" = "%lld golpes";

/* Warmup setting title */
"setting_warmup" = "Calentamiento";

/* Warmup setting help text */
"help_warmup" = "Muestras antes de que se active la detección. Los filtros necesitan tiempo para estabilizarse. A 50 Hz, 50 muestras = 1 segundo.";

/* Report interval setting title */
"setting_report_interval" = "Intervalo de Informe";

/* Report interval setting help text */
"help_report_interval" = "Intervalo de sondeo del acelerómetro. 10 ms = 100 Hz (predeterminado), 5 ms = 200 Hz, 20 ms = 50 Hz.";


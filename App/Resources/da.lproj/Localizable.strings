/* Detection paused indicator */
"status_paused" = "Sat på pause";

/* Basic Settings Section */

/* Reactivity setting title */
"setting_reactivity" = "Reaktivitet";

/* Reactivity setting help text */
"help_reactivity" = "Vindue for responsen på påvirkningens kraft. Nedre skyder = svageste kraft der udløser. Øvre skyder = kraft for maksimal respons. Højere værdier reagerer på lettere påvirkninger.";

/* Volume setting title */
"setting_volume" = "Lydstyrke";

/* Volume setting help text */
"help_volume" = "Vindue for lydafspilningsniveau. Intensiteten mappes lineært mellem lav og høj. Klipvalg følger også intensiteten — lettere påvirkninger afspiller kortere klip.";

/* Flash opacity setting title */
"setting_flash_opacity" = "Blitz-opacitet";

/* Flash opacity setting help text */
"help_flash_opacity" = "Vindue for skærmblitzens lysstyrke. Envelope-timing formes af intensitet. Afgrænset af lydklippets varighed.";

/* Sensitivity Ruler Labels */

/* Ruler label: hardest impact */
"tier_hard" = "Hård";

/* Ruler label: firm impact */
"tier_firm" = "Fast";

/* Ruler label: medium impact (abbreviated) */
"tier_medium" = "Middel";

/* Ruler label: light impact */
"tier_light" = "Let";

/* Ruler label: lightest impact */
"tier_tap" = "Tryk";

/* Sensitivity & Sensors Section */

/* Sensitivity & Sensors accordion title */
"section_sensitivity_sensors" = "Følsomhed og sensorer";

/* Sensor consensus setting title */
"setting_consensus" = "Sensorkonsensus";

/* Sensor consensus setting help text */
"help_consensus" = "Antal sensorer der uafhængigt skal registrere en påvirkning før udløsning. Begrænset til antallet af sensorer der leverer data.";

/* Sensor consensus count */
"consensus_format" = "%lld sensorer";

/* Cooldown setting title */
"setting_cooldown" = "Nedkøling";

/* Cooldown setting help text */
"help_cooldown" = "Minimumstid mellem reaktioner. 0 = kun begrænset af det afspillende klips varighed.";

/* Accelerometer tuning section header */
"section_accel_tuning" = "Accelerometer-indstilling";

/* Frequency band setting title */
"setting_frequency_band" = "Frekvensbånd";

/* Frequency band setting help text */
"help_frequency_band" = "Båndpasfilter på rå accelerometerdata. Lav = højpas-afskæring (afviser gulvvibrationer). Høj = lavpas-afskæring (afviser elektronisk støj).";

/* Spike threshold setting title */
"setting_spike_threshold" = "Spidsværdi-tærskel";

/* Spike threshold setting help text */
"help_spike_threshold" = "Minimum filtreret størrelsesorden (g-kraft) for at betragte det som en potentiel påvirkning. Anvendes efter båndpasfiltrering. Højere værdier kræver større kraft.";

/* Crest factor setting title */
"setting_crest_factor" = "Crest Factor";

/* Crest factor setting help text */
"help_crest_factor" = "Topsignalet skal overstige baggrunds-RMS med denne faktor. Skarpe skrivebordsstød topper langt over baggrunden. Fodtrin hæver baggrunden sammen med toppen. Højere værdier afviser mere omgivende vibration.";

/* Rise rate setting title */
"setting_rise_rate" = "Rise Rate";

/* Rise rate setting help text */
"help_rise_rate" = "Minimum størrelsesforøgelse mellem på hinanden følgende prøver. Direkte påvirkninger stiger på 1-2 prøver. Overførte vibrationer stiger gradvist. Højere værdier afviser indirekte vibration.";

/* Confirmations setting title */
"setting_confirmations" = "Bekræftelser";

/* Confirmations setting help text */
"help_confirmations" = "Over-tærskels-prøver påkrævet i 120ms detektionsvinduet. Direkte slag producerer 3-5 høje prøver. Enkelte stød producerer 1-2.";

/* Confirmation hit count */
"confirmations_format" = "%lld slag";

/* Warmup setting title */
"setting_warmup" = "Opvarmning";

/* Warmup setting help text */
"help_warmup" = "Prøver før detektion aktiveres. Filtre har brug for tid til at stabilisere sig. Ved 50 Hz, 50 prøver = 1 sekund.";

/* Report interval setting title */
"setting_report_interval" = "Rapporteringsinterval";

/* Report interval setting help text */
"help_report_interval" = "Accelerometer-pollingsinterval. 10ms = 100 Hz (standard), 5ms = 200 Hz, 20ms = 50 Hz.";


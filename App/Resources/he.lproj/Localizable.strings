"help_brightness_boost" = "How much above your current brightness level to spike. 50% adds 0.5 to a max of 1.0.";
"help_brightness_threshold" = "Impact intensity required to trigger the brightness spike. Lighter impacts below this level are ignored.";
"help_display_brightness" = "Briefly spikes display brightness above your current level on impact, then fades back. Uses DisplayServices (private framework, loaded at runtime).";
"help_display_tint" = "Briefly tints the display pink by adjusting the gamma table. Skipped on macOS 26+. Uses public CoreGraphics APIs.";
"help_haptic" = "Fires rapid Force Touch haptic pulses on impact. Pulse density scales with reaction intensity. Requires a Mac with a Force Touch trackpad.";
"help_haptic_intensity" = "Multiplier for the number of haptic pulses per reaction. Higher values produce denser bursts.";
"help_hp_rise_rate" = "Minimum magnitude increase between motion samples. Sharp head jolts rise fast. Gradual movement rises slowly.";
"help_hp_spike_threshold" = "Minimum userAcceleration magnitude (g-force) to consider as impact. Normal head movement is below 0.05g.";
"help_keyboard_leds" = "Flashes the Caps Lock LED and oscillates the keyboard backlight on each reaction. Both restore to their original state after the animation.";
"help_led_brightness" = "Range of pulse brightness scaled by impact intensity. Min for the lightest reactions, Max for the strongest.";
"help_mic_rise_rate" = "Minimum amplitude increase between audio buffers. Sharp transients rise fast. Gradual ambient changes rise slowly.";
"help_mic_spike_threshold" = "Minimum HP-filtered audio amplitude to consider as impact. Higher values require louder desk sounds.";
"help_notifications" = "Posts a system notification for each reaction. Draws from the moan/event phrase pools.";
"help_source_audio_peripheral" = "Fires a reaction when audio devices (headphones, speakers) are added or removed.";
"help_source_bluetooth" = "Fires a reaction when Bluetooth devices connect or disconnect.";
"help_source_display" = "Fires a reaction when a display is connected, disconnected, or reconfigured.";
"help_source_keyboard" = "Fires a reaction when keyboard typing rate crosses the configured threshold. Requires Input Monitoring permission.";
"help_source_mouse" = "Fires reactions on mouse button clicks and sustained scroll-wheel activity. Only appears when an external mouse is connected.";
"help_source_power" = "Fires a reaction when the power adapter is connected or disconnected.";
"help_source_sleep_wake" = "Fires a reaction when the Mac goes to sleep or wakes up.";
"help_source_thunderbolt" = "Fires a reaction when Thunderbolt devices attach or detach.";
"help_source_trackpad" = "Fires reactions on trackpad activity — scrolling, swiping, finger contact, and tapping. Includes per-detection-mode sensitivity tuning.";
"help_source_usb" = "Fires a reaction when a USB device is plugged in or unplugged.";
"help_tint_intensity" = "How strongly to crush the green and blue gamma channels. Higher values produce a more vivid pink flash.";
"help_trackpad_circle" = "Detects rapid finger circles on trackpad — fires the long moan at max volume.";
"help_trackpad_contact" = "Duration range for resting-finger detection. Fires after the left-edge duration; reaches full intensity at the right-edge duration. Requires at least a brief scroll gesture to detect contact.";
"help_trackpad_scroll" = "Activity range for scroll and swipe detection. Left edge = starts firing, right edge = full intensity. Lower values react to lighter touches.";
"help_trackpad_tap" = "Taps-per-second range for rapid tap detection. Left edge = minimum rate to fire, right edge = full intensity rate. Counts any quick click (< 300 ms hold) from any input device.";
"help_trackpad_window" = "Duration of the sliding window used to accumulate trackpad activity. Longer windows are more forgiving but slower to react.";
"help_visual_response_flash" = "Flashes an overlay on selected displays when an impact or event is detected. Opacity scales with intensity.";

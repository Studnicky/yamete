/* Yamete — Greek Localizable Strings */

/* Header Section */

/* Daily impact counter */
"impacts_today" = "%lld κρούσεις σήμερα";

/* Last impact tier label */
"last_impact" = "τελευταία: %@";

/* Detection paused indicator */
"status_paused" = "Σε παύση";

/* Basic Settings Section */

/* Reactivity setting title */
"setting_reactivity" = "Αντιδραστικότητα";

/* Reactivity setting help text */
"help_reactivity" = "Παράθυρο απόκρισης δύναμης κρούσης. Κάτω ρυθμιστής = ελάχιστη δύναμη που ενεργοποιεί. Άνω ρυθμιστής = δύναμη για μέγιστη απόκριση. Υψηλότερες τιμές ανταποκρίνονται σε ελαφρύτερες κρούσεις.";

/* Volume setting title */
"setting_volume" = "Ένταση";

/* Volume setting help text */
"help_volume" = "Παράθυρο επιπέδου αναπαραγωγής ήχου. Η ένταση χαρτογραφείται γραμμικά μεταξύ χαμηλού και υψηλού. Η επιλογή κλιπ ακολουθεί επίσης την ένταση — οι ελαφρύτερες κρούσεις αναπαράγουν κοντύτερα κλιπ.";

/* Flash opacity setting title */
"setting_flash_opacity" = "Αδιαφάνεια αναλαμπής";

/* Flash opacity setting help text */
"help_flash_opacity" = "Παράθυρο φωτεινότητας αναλαμπής οθόνης. Ο χρονισμός envelope διαμορφώνεται από την ένταση. Περιορισμένο εντός της διάρκειας του ηχητικού κλιπ.";

/* Sensitivity Ruler Labels */

/* Ruler label: hardest impact */
"tier_hard" = "Δυνατή";

/* Ruler label: firm impact */
"tier_firm" = "Σταθερή";

/* Ruler label: medium impact (abbreviated) */
"tier_medium" = "Μέτρια";

/* Ruler label: light impact */
"tier_light" = "Ελαφριά";

/* Ruler label: lightest impact */
"tier_tap" = "Άγγιγμα";

/* Sensitivity & Sensors Section */

/* Sensitivity & Sensors accordion title */
"section_sensitivity_sensors" = "Ευαισθησία & Αισθητήρες";

/* Sensor consensus setting title */
"setting_consensus" = "Συναίνεση αισθητήρων";

/* Sensor consensus setting help text */
"help_consensus" = "Αριθμός αισθητήρων που πρέπει να ανιχνεύσουν ανεξάρτητα μια κρούση πριν την ενεργοποίηση. Περιορισμένο στον αριθμό των αισθητήρων που παρέχουν δεδομένα.";

/* Sensor consensus count */
"consensus_format" = "%lld αισθητήρες";

/* Cooldown setting title */
"setting_cooldown" = "Χρόνος επαναφοράς";

/* Cooldown setting help text */
"help_cooldown" = "Ελάχιστος χρόνος μεταξύ αντιδράσεων. 0 = περιορισμένο μόνο από τη διάρκεια του κλιπ που παίζει.";

/* Accelerometer tuning section header */
"section_accel_tuning" = "Ρύθμιση επιταχυνσιόμετρου";

/* Frequency band setting title */
"setting_frequency_band" = "Εύρος συχνοτήτων";

/* Frequency band setting help text */
"help_frequency_band" = "Φίλτρο ζώνης διέλευσης σε ακατέργαστα δεδομένα επιταχυνσιόμετρου. Χαμηλό = αποκοπή υψηλής συχνότητας (απορρίπτει δονήσεις δαπέδου). Υψηλό = αποκοπή χαμηλής συχνότητας (απορρίπτει ηλεκτρονικό θόρυβο).";

/* Spike threshold setting title */
"setting_spike_threshold" = "Κατώφλι αιχμής";

/* Spike threshold setting help text */
"help_spike_threshold" = "Ελάχιστο φιλτραρισμένο μέγεθος (δύναμη g) για να θεωρηθεί πιθανή κρούση. Εφαρμόζεται μετά το φιλτράρισμα ζώνης. Υψηλότερες τιμές απαιτούν μεγαλύτερη δύναμη.";

/* Crest factor setting title */
"setting_crest_factor" = "Crest Factor";

/* Crest factor setting help text */
"help_crest_factor" = "Το σήμα κορυφής πρέπει να υπερβαίνει το RMS παρασκηνίου κατά αυτό το πολλαπλάσιο. Απότομα χτυπήματα στο γραφείο ανεβαίνουν πολύ πάνω από το παρασκήνιο. Βήματα ανεβάζουν το παρασκήνιο μαζί με την κορυφή. Υψηλότερες τιμές απορρίπτουν περισσότερη περιβαλλοντική δόνηση.";

/* Rise rate setting title */
"setting_rise_rate" = "Rise Rate";

/* Rise rate setting help text */
"help_rise_rate" = "Ελάχιστη αύξηση μεγέθους μεταξύ διαδοχικών δειγμάτων. Άμεσες κρούσεις ανεβαίνουν σε 1-2 δείγματα. Μεταδοτικές δονήσεις ανεβαίνουν σταδιακά. Υψηλότερες τιμές απορρίπτουν έμμεσες δονήσεις.";

/* Confirmations setting title */
"setting_confirmations" = "Επιβεβαιώσεις";

/* Confirmations setting help text */
"help_confirmations" = "Δείγματα πάνω από το κατώφλι που απαιτούνται στο παράθυρο ανίχνευσης 120ms. Άμεσα χτυπήματα παράγουν 3-5 υψηλά δείγματα. Μεμονωμένα χτυπήματα παράγουν 1-2.";

/* Confirmation hit count */
"confirmations_format" = "%lld χτυπήματα";

/* Warmup setting title */
"setting_warmup" = "Προθέρμανση";

/* Warmup setting help text */
"help_warmup" = "Δείγματα πριν ενεργοποιηθεί η ανίχνευση. Τα φίλτρα χρειάζονται χρόνο για να σταθεροποιηθούν. Στα 50 Hz, 50 δείγματα = 1 δευτερόλεπτο.";

/* Report interval setting title */
"setting_report_interval" = "Διάστημα αναφοράς";

/* Report interval setting help text */
"help_report_interval" = "Διάστημα δειγματοληψίας επιταχυνσιόμετρου. 10ms = 100 Hz (προεπιλογή), 5ms = 200 Hz, 20ms = 50 Hz.";


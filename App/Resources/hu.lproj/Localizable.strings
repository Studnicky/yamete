/* Ruler label: light impact */
"tier_light" = "Könnyű";

/* Ruler label: lightest impact */
"tier_tap" = "Érintés";

/* Sensitivity & Sensors Section */

/* Sensitivity & Sensors accordion title */
"section_sensitivity_sensors" = "Érzékenység és érzékelők";

/* Sensor consensus setting title */
"setting_consensus" = "Érzékelők konszenzusa";

/* Sensor consensus setting help text */
"help_consensus" = "Az érzékelők száma, amelyeknek egymástól függetlenül kell ütést érzékelniük az indítás előtt. Adatot szolgáltató érzékelők számára korlátozva.";

/* Sensor consensus count */
"consensus_format" = "%lld érzékelő";

/* Cooldown setting title */
"setting_cooldown" = "Visszatöltési idő";

/* Cooldown setting help text */
"help_cooldown" = "Minimális idő a reakciók között. 0 = csak a lejátszott klip időtartama által korlátozva.";

/* Accelerometer tuning section header */
"section_accel_tuning" = "Gyorsulásmérő hangolása";

/* Frequency band setting title */
"setting_frequency_band" = "Frekvenciasáv";

/* Frequency band setting help text */
"help_frequency_band" = "Sávszűrő a nyers gyorsulásmérő-adatokon. Alacsony = felülvágó frekvencia (padlórezgések elutasítása). Magas = alulvágó frekvencia (elektronikus zaj elutasítása).";

/* Spike threshold setting title */
"setting_spike_threshold" = "Csúcsérték-küszöb";

/* Spike threshold setting help text */
"help_spike_threshold" = "Minimális szűrt magnitúdó (g-erő) potenciális ütésnek tekintéshez. A sávszűrés után alkalmazva. Magasabb értékek erősebb erőt igényelnek.";

/* Crest factor setting title */
"setting_crest_factor" = "Crest Factor";

/* Crest factor setting help text */
"help_crest_factor" = "A csúcsjel ennyiszeresével kell meghaladnia a háttér RMS-t. Az asztalra mért éles ütések messze a háttér fölé emelkednek. A lépések a hátteret is emelik a csúccsal együtt. Magasabb értékek több környezeti rezgést utasítanak el.";

/* Rise rate setting title */
"setting_rise_rate" = "Rise Rate";

/* Rise rate setting help text */
"help_rise_rate" = "Minimális magnitúdónövekedés egymást követő minták között. A közvetlen ütések 1-2 minta alatt emelkednek. Az átvitt rezgések fokozatosan emelkednek. Magasabb értékek közvetett rezgéseket utasítanak el.";

/* Confirmations setting title */
"setting_confirmations" = "Megerősítések";

/* Confirmations setting help text */
"help_confirmations" = "A 120ms-os érzékelési ablakon belül szükséges, küszöb feletti minták. A közvetlen ütések 3-5 magas mintát produkálnak. Az egyszeri lökések 1-2-t.";

/* Confirmation hit count */
"confirmations_format" = "%lld találat";

/* Warmup setting title */
"setting_warmup" = "Felmelegítés";

/* Warmup setting help text */
"help_warmup" = "Minták az érzékelés aktiválása előtt. A szűrőknek időre van szükségük a beálláshoz. 50 Hz-en, 50 minta = 1 másodperc.";

/* Report interval setting title */
"setting_report_interval" = "Jelentési intervallum";

/* Report interval setting help text */
"help_report_interval" = "Gyorsulásmérő lekérdezési intervalluma. 10ms = 100 Hz (alapértelmezett), 5ms = 200 Hz, 20ms = 50 Hz.";


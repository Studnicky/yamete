/* Basic Settings Section */

/* Reactivity setting title */
"setting_reactivity" = "Reaktivitás";

/* Reactivity setting help text */
"help_reactivity" = "Az ütéserő-válasz ablaka. Alsó csúszka = a leggyengébb kiváltó erő. Felső csúszka = a maximális válaszhoz szükséges erő. Magasabb értékek könnyebb ütésekre is reagálnak.";

/* Volume setting title */
"setting_volume" = "Hangerő";

/* Volume setting help text */
"help_volume" = "Hanglejátszási szint ablaka. Az intenzitás lineárisan van leképezve az alacsony és magas között. A klipkiválasztás szintén az intenzitást követi — könnyebb ütések rövidebb klipeket játszanak le.";

/* Flash opacity setting title */
"setting_flash_opacity" = "Villanás átlátszatlansága";

/* Flash opacity setting help text */
"help_flash_opacity" = "A képernyővillanás fényerejének ablaka. A burkoló időzítése az intenzitás által formált. A hangklip időtartamán belül korlátozva.";


/* Yamete — Русский (Russian) Localizable Strings */

/* Header Section */

/* Daily impact counter */
"impacts_today" = "%lld ударов сегодня";

/* Last impact tier label */
"last_impact" = "последний: %@";

/* Detection paused indicator */
"status_paused" = "Пауза";

/* Basic Settings Section */

/* Reactivity setting title */
"setting_reactivity" = "Реактивность";

/* Reactivity setting help text */
"help_reactivity" = "Окно отклика на силу удара. Нижний ползунок = минимальная сила срабатывания. Верхний ползунок = сила для максимального отклика. Более высокие значения реагируют на более слабые удары.";

/* Volume setting title */
"setting_volume" = "Громкость";

/* Volume setting help text */
"help_volume" = "Окно уровня воспроизведения звука. Интенсивность линейно отображается между минимумом и максимумом. Выбор клипа также зависит от интенсивности — более слабые удары воспроизводят более короткие клипы.";

/* Flash opacity setting title */
"setting_flash_opacity" = "Непрозрачность вспышки";

/* Flash opacity setting help text */
"help_flash_opacity" = "Окно яркости вспышки на экране. Форма огибающей определяется интенсивностью. Ограничена длительностью звукового клипа.";

/* Sensitivity Ruler Labels */

/* Ruler label: hardest impact */
"tier_hard" = "Сильный";

/* Ruler label: firm impact */
"tier_firm" = "Твёрдый";

/* Ruler label: medium impact (abbreviated) */
"tier_medium" = "Ср.";

/* Ruler label: light impact */
"tier_light" = "Лёгкий";

/* Ruler label: lightest impact */
"tier_tap" = "Касание";

/* Sensitivity & Sensors Section */

/* Sensitivity & Sensors accordion title */
"section_sensitivity_sensors" = "Чувствительность и датчики";

/* Sensor consensus setting title */
"setting_consensus" = "Консенсус датчиков";

/* Sensor consensus setting help text */
"help_consensus" = "Количество датчиков, которые должны независимо обнаружить удар перед срабатыванием. Ограничено числом датчиков, передающих данные.";

/* Sensor consensus count */
"consensus_format" = "%lld датчиков";

/* Cooldown setting title */
"setting_cooldown" = "Задержка";

/* Cooldown setting help text */
"help_cooldown" = "Минимальное время между реакциями. 0 = ограничено только длительностью воспроизводимого клипа.";

/* Accelerometer tuning section header */
"section_accel_tuning" = "Настройка акселерометра";

/* Frequency band setting title */
"setting_frequency_band" = "Полоса частот";

/* Frequency band setting help text */
"help_frequency_band" = "Полосовой фильтр на необработанных данных акселерометра. Нижнее значение = порог ФВЧ (отсекает напольные вибрации). Верхнее значение = порог ФНЧ (отсекает электронные шумы).";

/* Spike threshold setting title */
"setting_spike_threshold" = "Порог пика";

/* Spike threshold setting help text */
"help_spike_threshold" = "Минимальная отфильтрованная амплитуда (g-сила) для распознавания потенциального удара. Применяется после полосовой фильтрации. Более высокие значения требуют большей силы.";

/* Crest factor setting title */
"setting_crest_factor" = "Crest Factor";

/* Crest factor setting help text */
"help_crest_factor" = "Пиковый сигнал должен превышать фоновое RMS на этот множитель. Резкие удары по столу значительно превышают фон. Шаги повышают фон вместе с пиком. Более высокие значения отсекают больше фоновых вибраций.";

/* Rise rate setting title */
"setting_rise_rate" = "Rise Rate";

/* Rise rate setting help text */
"help_rise_rate" = "Минимальное увеличение амплитуды между последовательными отсчётами. Прямые удары нарастают за 1-2 отсчёта. Переданные вибрации нарастают постепенно. Более высокие значения отсекают косвенные вибрации.";

/* Confirmations setting title */
"setting_confirmations" = "Подтверждения";

/* Confirmations setting help text */
"help_confirmations" = "Отсчёты выше порога, необходимые в окне обнаружения 120 мс. Прямые удары дают 3-5 высоких отсчётов. Одиночные толчки дают 1-2.";

/* Confirmation hit count */
"confirmations_format" = "%lld попаданий";

/* Warmup setting title */
"setting_warmup" = "Прогрев";

/* Warmup setting help text */
"help_warmup" = "Отсчёты до активации обнаружения. Фильтрам нужно время для стабилизации. При 50 Гц 50 отсчётов = 1 секунда.";

/* Report interval setting title */
"setting_report_interval" = "Интервал опроса";

/* Report interval setting help text */
"help_report_interval" = "Интервал опроса акселерометра. 10 мс = 100 Гц (по умолчанию), 5 мс = 200 Гц, 20 мс = 50 Гц.";


"help_flash_displays" = "Wählen Sie, welche Monitore bei einem Einschlag die Blitz-Überlagerung anzeigen.";

/* Audio output setting title */
"setting_audio_output" = "Audioausgabe";

/* Audio output setting help text */
"help_audio_output" = "Wählen Sie, welche Audiogeräte Einschlaggeräusche abspielen. Keine Auswahl = kein Audio.";


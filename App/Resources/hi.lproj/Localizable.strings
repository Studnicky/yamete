/* Audio output setting title */
"setting_audio_output" = "ऑडियो आउटपुट";

/* Audio output setting help text */
"help_audio_output" = "चुनें कि कौन से ऑडियो डिवाइस प्रभाव ध्वनियां चलाएं। कोई चयन नहीं = कोई ऑडियो नहीं।";


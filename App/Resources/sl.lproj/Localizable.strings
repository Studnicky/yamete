"setting_crest_factor" = "Crest Factor";

/* Crest factor setting help text */
"help_crest_factor" = "Koničasti signal mora preseči ozadje RMS za ta množitelj. Ostri udarci po mizi precej presegajo ozadje. Koraki dvigajo ozadje skupaj s konico. Višje vrednosti zavrnejo več okoliških vibracij.";

/* Rise rate setting title */
"setting_rise_rate" = "Rise Rate";

/* Rise rate setting help text */
"help_rise_rate" = "Minimalno povečanje amplitude med zaporednimi vzorci. Neposredni udarci narastejo v 1-2 vzorcih. Prenesene vibracije naraščajo postopoma. Višje vrednosti zavrnejo posredne vibracije.";

/* Confirmations setting title */
"setting_confirmations" = "Potrditve";

/* Confirmations setting help text */
"help_confirmations" = "Vzorci nad pragom, potrebni v 120 ms oknu zaznavanja. Neposredni udarci dajo 3-5 visokih vzorcev. Enkratni sunki dajo 1-2.";


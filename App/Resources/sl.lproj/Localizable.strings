"setting_spike_threshold" = "Prag konice";

/* Spike threshold setting help text */
"help_spike_threshold" = "Minimalna filtrirana amplituda (g-sila), ki se upošteva kot potencialni udarec. Uporablja se po pasovnem filtriranju. Višje vrednosti zahtevajo večjo silo.";


/* Basic Settings Section */

/* Reactivity setting title */
"setting_reactivity" = "Reactivity";

/* Reactivity setting help text */
"help_reactivity" = "Impact force response window. Low thumb = weakest force that triggers. High thumb = force for maximum response. Higher values respond to lighter impacts.";

/* Volume setting title */
"setting_volume" = "Volume";

/* Volume setting help text */
"help_volume" = "Audio playback level window. Intensity maps linearly between low and high. Clip selection also follows intensity — lighter impacts play shorter clips.";

/* Flash opacity setting title */
"setting_flash_opacity" = "Flash Opacity";

/* Flash opacity setting help text */
"help_flash_opacity" = "Screen flash brightness window. Envelope timing shaped by intensity. Gated inside the sound clip duration.";


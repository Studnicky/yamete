"tier_tap" = "Tap";

/* Sensitivity & Sensors Section */

/* Sensitivity & Sensors accordion title */
"section_sensitivity_sensors" = "Sensitivity & Sensors";

/* Sensor consensus setting title */
"setting_consensus" = "Sensor Consensus";

/* Sensor consensus setting help text */
"help_consensus" = "Number of sensors that must independently detect an impact before triggering. Clamped to the number of sensors delivering data.";

/* Sensor consensus count */
"consensus_format" = "%lld sensors";

/* Cooldown setting title */
"setting_cooldown" = "Cooldown";

/* Cooldown setting help text */
"help_cooldown" = "Minimum time between reactions. 0 = gated only by the playing clip's duration.";

/* Accelerometer tuning section header */
"section_accel_tuning" = "Accelerometer Tuning";

/* Frequency band setting title */
"setting_frequency_band" = "Frequency Band";

/* Frequency band setting help text */
"help_frequency_band" = "Bandpass filter on raw accelerometer data. Low = high-pass cutoff (rejects floor vibrations). High = low-pass cutoff (rejects electronic noise).";

/* Spike threshold setting title */
"setting_spike_threshold" = "Spike Threshold";

/* Spike threshold setting help text */
"help_spike_threshold" = "Minimum filtered magnitude (g-force) to consider as a potential impact. Applied after bandpass filtering. Higher values require stronger force.";

/* Crest factor setting title */
"setting_crest_factor" = "Crest Factor";

/* Crest factor setting help text */
"help_crest_factor" = "Peak signal must exceed background RMS by this multiple. Sharp desk hits spike well above background. Footsteps raise background along with peak. Higher values reject more ambient vibration.";

/* Rise rate setting title */
"setting_rise_rate" = "Rise Rate";

/* Rise rate setting help text */
"help_rise_rate" = "Minimum magnitude increase between consecutive samples. Direct impacts rise in 1-2 samples. Transmitted vibrations rise gradually. Higher values reject indirect vibration.";

/* Confirmations setting title */
"setting_confirmations" = "Confirmations";

/* Confirmations setting help text */
"help_confirmations" = "Above-threshold samples required in the 120ms detection window. Direct hits produce 3-5 high samples. Single jolts produce 1-2.";

/* Confirmation hit count */
"confirmations_format" = "%lld hits";

/* Warmup setting title */
"setting_warmup" = "Warmup";

/* Warmup setting help text */
"help_warmup" = "Samples before detection activates. Filters need time to settle. At 50 Hz, 50 samples = 1 second.";

/* Report interval setting title */
"setting_report_interval" = "Report Interval";

/* Report interval setting help text */
"help_report_interval" = "Accelerometer polling interval. 10ms = 100 Hz (default), 5ms = 200 Hz, 20ms = 50 Hz.";


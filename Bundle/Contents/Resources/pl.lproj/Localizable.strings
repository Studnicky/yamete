"help_flash_displays" = "Wybierz, które monitory wyświetlają nakładkę błysku przy uderzeniu.";

/* Audio output setting title */
"setting_audio_output" = "Wyjście Audio";

/* Audio output setting help text */
"help_audio_output" = "Wybierz, które urządzenia audio odtwarzają dźwięki uderzeń. Nic nie wybrano = brak audio.";

/* No audio output devices found message */
"no_output_devices" = "Nie znaleziono urządzeń wyjściowych";


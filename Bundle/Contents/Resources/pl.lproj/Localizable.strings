/* Yamete — Polish (pl) Localizable Strings */

/* Header Section */

/* Daily impact counter */
"impacts_today" = "%lld uderzeń dzisiaj";

/* Last impact tier label */
"last_impact" = "ostatnie: %@";

/* Detection paused indicator */
"status_paused" = "Wstrzymano";

/* Basic Settings Section */

/* Reactivity setting title */
"setting_reactivity" = "Reaktywność";

/* Reactivity setting help text */
"help_reactivity" = "Okno odpowiedzi na siłę uderzenia. Dolny suwak = najsłabsza siła wyzwalająca. Górny suwak = siła dla maksymalnej odpowiedzi. Wyższe wartości reagują na lżejsze uderzenia.";

/* Volume setting title */
"setting_volume" = "Głośność";

/* Volume setting help text */
"help_volume" = "Okno poziomu odtwarzania audio. Intensywność jest liniowo mapowana między niską a wysoką wartością. Wybór klipu również podąża za intensywnością — lżejsze uderzenia odtwarzają krótsze klipy.";

/* Flash opacity setting title */
"setting_flash_opacity" = "Przezroczystość Błysku";

/* Flash opacity setting help text */
"help_flash_opacity" = "Okno jasności błysku ekranu. Czas obwiedni kształtowany jest przez intensywność. Bramkowane w czasie trwania klipu dźwiękowego.";

/* Sensitivity Ruler Labels */

/* Ruler label: hardest impact */
"tier_hard" = "Mocne";

/* Ruler label: firm impact */
"tier_firm" = "Silne";

/* Ruler label: medium impact (abbreviated) */
"tier_medium" = "Śred";

/* Ruler label: light impact */
"tier_light" = "Lekkie";

/* Ruler label: lightest impact */
"tier_tap" = "Stuk";

/* Sensitivity & Sensors Section */

/* Sensitivity & Sensors accordion title */
"section_sensitivity_sensors" = "Czułość i Czujniki";

/* Sensor consensus setting title */
"setting_consensus" = "Konsensus Czujników";

/* Sensor consensus setting help text */
"help_consensus" = "Liczba czujników, które muszą niezależnie wykryć uderzenie przed wyzwoleniem. Ograniczona do liczby czujników dostarczających dane.";

/* Sensor consensus count */
"consensus_format" = "%lld czujników";

/* Cooldown setting title */
"setting_cooldown" = "Czas Odliczania";

/* Cooldown setting help text */
"help_cooldown" = "Minimalny czas między reakcjami. 0 = bramkowane tylko przez czas trwania odtwarzanego klipu.";

/* Accelerometer tuning section header */
"section_accel_tuning" = "Strojenie Akcelerometru";

/* Frequency band setting title */
"setting_frequency_band" = "Pasmo Częstotliwości";

/* Frequency band setting help text */
"help_frequency_band" = "Filtr pasmowy na surowych danych akcelerometru. Niskie = odcięcie górnoprzepustowe (odrzuca wibracje podłogi). Wysokie = odcięcie dolnoprzepustowe (odrzuca szumy elektroniczne).";

/* Spike threshold setting title */
"setting_spike_threshold" = "Próg Skoku";

/* Spike threshold setting help text */
"help_spike_threshold" = "Minimalna przefiltrowana wielkość (siła g) do rozważenia jako potencjalne uderzenie. Stosowane po filtracji pasmowej. Wyższe wartości wymagają silniejszej siły.";

/* Crest factor setting title */
"setting_crest_factor" = "Współczynnik Szczytu";

/* Crest factor setting help text */
"help_crest_factor" = "Sygnał szczytowy musi przekraczać tło RMS o tę wielokrotność. Ostre uderzenia biurka skaczą daleko powyżej tła. Kroki podwyższają tło razem ze szczytem. Wyższe wartości odrzucają więcej wibracji otoczenia.";

/* Rise rate setting title */
"setting_rise_rate" = "Szybkość Wzrostu";

/* Rise rate setting help text */
"help_rise_rate" = "Minimalny wzrost wielkości między kolejnymi próbkami. Bezpośrednie uderzenia rosną w 1-2 próbkach. Przenoszone wibracje rosną stopniowo. Wyższe wartości odrzucają pośrednie wibracje.";

/* Confirmations setting title */
"setting_confirmations" = "Potwierdzenia";

/* Confirmations setting help text */
"help_confirmations" = "Próbki powyżej progu wymagane w oknie detekcji 120ms. Bezpośrednie trafienia produkują 3-5 wysokich próbek. Pojedyncze szarpnięcia produkują 1-2.";

/* Confirmation hit count */
"confirmations_format" = "%lld trafień";

/* Warmup setting title */
"setting_warmup" = "Rozgrzewanie";

/* Warmup setting help text */
"help_warmup" = "Próbki przed aktywacją detekcji. Filtry potrzebują czasu na ustabilizowanie się. Przy 50 Hz, 50 próbek = 1 sekunda.";

/* Report interval setting title */
"setting_report_interval" = "Interwał Raportowania";

/* Report interval setting help text */
"help_report_interval" = "Interwał odpytywania akcelerometru. 10ms = 100 Hz (domyślnie), 5ms = 200 Hz, 20ms = 50 Hz.";


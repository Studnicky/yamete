/* Basic Settings Section */

/* Reactivity setting title */
"setting_reactivity" = "Reaktivitas";

/* Reactivity setting help text */
"help_reactivity" = "Jendela respons gaya benturan. Ibu jari bawah = gaya terkecil yang memicu. Ibu jari atas = gaya untuk respons maksimum. Nilai lebih tinggi merespons benturan lebih ringan.";

/* Volume setting title */
"setting_volume" = "Volume";

/* Volume setting help text */
"help_volume" = "Jendela tingkat pemutaran audio. Intensitas dipetakan secara linier antara rendah dan tinggi. Pemilihan klip juga mengikuti intensitas — benturan lebih ringan memainkan klip lebih pendek.";


"setting_flash_opacity" = "Opasitas Kilat";

/* Flash opacity setting help text */
"help_flash_opacity" = "Jendela kecerahan kilat layar. Waktu amplop dibentuk oleh intensitas. Terkunci dalam durasi klip suara.";


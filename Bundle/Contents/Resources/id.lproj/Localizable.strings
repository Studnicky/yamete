/* Sensitivity & Sensors accordion title */
"section_sensitivity_sensors" = "Sensitivitas & Sensor";

/* Sensor consensus setting title */
"setting_consensus" = "Konsensus Sensor";

/* Sensor consensus setting help text */
"help_consensus" = "Jumlah sensor yang harus mendeteksi benturan secara independen sebelum memicu. Dibatasi oleh jumlah sensor yang mengirimkan data.";

/* Sensor consensus count */

"setting_cooldown" = "Cooldown";

/* Cooldown setting help text */
"help_cooldown" = "Minimálny čas medzi reakciami. 0 = obmedzené iba trvaním prehrávaného klipu.";

/* Accelerometer tuning section header */
"section_accel_tuning" = "Nastavenie akcelerometra";

/* Frequency band setting title */
"setting_frequency_band" = "Frekvenčné pásmo";

/* Frequency band setting help text */
"help_frequency_band" = "Pásmový filter na surových dátach akcelerometra. Nízka hodnota = prah horného priepustu (odmieta vibrácie podlahy). Vysoká hodnota = prah dolného priepustu (odmieta elektronický šum).";

/* Spike threshold setting title */
"setting_spike_threshold" = "Prah špičky";

/* Spike threshold setting help text */
"help_spike_threshold" = "Minimálna filtrovaná magnitúda (g-sila) považovaná za potenciálny náraz. Aplikuje sa po pásmovom filtrovaní. Vyššie hodnoty vyžadujú väčšiu silu.";

/* Crest factor setting title */
"setting_crest_factor" = "Crest Factor";

/* Crest factor setting help text */
"help_crest_factor" = "Špičkový signál musí prevyšovať pozadie RMS o tento násobok. Prudké údery do stola výrazne prevyšujú pozadie. Kroky zvyšujú pozadie spolu so špičkou. Vyššie hodnoty odmietajú viac okolitých vibrácií.";

/* Rise rate setting title */
"setting_rise_rate" = "Rise Rate";

/* Rise rate setting help text */
"help_rise_rate" = "Minimálny nárast magnitúdy medzi po sebe nasledujúcimi vzorkami. Priame nárazy narastajú za 1-2 vzorky. Prenášané vibrácie narastajú postupne. Vyššie hodnoty odmietajú nepriame vibrácie.";

/* Confirmations setting title */
"setting_confirmations" = "Potvrdenia";

/* Confirmations setting help text */
"help_confirmations" = "Vzorky nad prahom požadované v 120 ms detekčnom okne. Priame údery produkujú 3-5 vysokých vzoriek. Jednorazové otrasy produkujú 1-2.";

/* Confirmation hit count */
"confirmations_format" = "%lld zásahov";

/* Warmup setting title */
"setting_warmup" = "Zahriatie";

/* Warmup setting help text */
"help_warmup" = "Vzorky pred aktiváciou detekcie. Filtre potrebujú čas na ustálenie. Pri 50 Hz, 50 vzoriek = 1 sekunda.";

/* Report interval setting title */
"setting_report_interval" = "Interval hlásenia";

/* Report interval setting help text */
"help_report_interval" = "Interval snímania akcelerometra. 10 ms = 100 Hz (predvolené), 5 ms = 200 Hz, 20 ms = 50 Hz.";


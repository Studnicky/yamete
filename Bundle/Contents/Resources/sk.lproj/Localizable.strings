/* Sensitivity & Sensors accordion title */
"section_sensitivity_sensors" = "Citlivosť a senzory";

/* Sensor consensus setting title */
"setting_consensus" = "Zhoda senzorov";

/* Sensor consensus setting help text */
"help_consensus" = "Počet senzorov, ktoré musia nezávisle detegovať náraz pred spustením. Obmedzené na počet senzorov poskytujúcich dáta.";

/* Sensor consensus count */
"consensus_format" = "%lld senzorov";


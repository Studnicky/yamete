"setting_flash_displays" = "Écrans avec Flash";

/* Flash displays setting help text */
"help_flash_displays" = "Sélectionnez les moniteurs qui affichent le flash lors d'un impact.";

/* Audio output setting title */
"setting_audio_output" = "Sortie Audio";


"tier_tap_full" = "Klepnutí";

/* Impact tier name: light */
"tier_light_full" = "Lehký";

/* Impact tier name: medium */
"tier_medium_full" = "Střední";

/* Impact tier name: firm */
"tier_firm_full" = "Pevný";

/* Impact tier name: hardest */
"tier_hard_full" = "Silný";


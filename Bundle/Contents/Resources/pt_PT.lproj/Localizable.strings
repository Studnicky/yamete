/* Percentage format */
"unit_percent" = "%lld%%";

/* Hertz format */
"unit_hz" = "%lld Hz";

/* G-force format */
"unit_gforce" = "%.3fg";

/* Multiplier format */
"unit_multiplier" = "%.1f\u00D7";

/* Seconds format */
"unit_seconds" = "%.1fs";

/* Milliseconds format */
"unit_milliseconds" = "%.0fms";

/* Devices Section */

/* Devices accordion title */
"section_devices" = "Dispositivos";

/* Devices section subtitle: display and audio count */
"devices_subtitle" = "%1$lld monitores, %2$lld áudio";

/* Flash displays setting title */
"setting_flash_displays" = "Monitores Flash";

/* Flash displays setting help text */
"help_flash_displays" = "Selecione quais monitores mostram a sobreposição de flash no impacto.";

/* Audio output setting title */
"setting_audio_output" = "Saída de Áudio";

/* Audio output setting help text */
"help_audio_output" = "Selecione quais dispositivos de áudio reproduzem sons de impacto. Nenhum selecionado = sem áudio.";

/* No audio output devices found message */
"no_output_devices" = "Nenhum dispositivo de saída encontrado";


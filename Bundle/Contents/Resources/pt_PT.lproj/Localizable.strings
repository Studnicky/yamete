/* Yamete — Portuguese Portugal (pt_PT) Localizable Strings */

/* Header Section */

/* Daily impact counter */
"impacts_today" = "%lld impactos hoje";

/* Last impact tier label */
"last_impact" = "último: %@";

/* Detection paused indicator */
"status_paused" = "Em pausa";

/* Basic Settings Section */

/* Reactivity setting title */
"setting_reactivity" = "Reatividade";

/* Reactivity setting help text */
"help_reactivity" = "Janela de resposta à força de impacto. Polegar inferior = força mais fraca que aciona. Polegar superior = força para resposta máxima. Valores mais altos respondem a impactos mais ligeiros.";

/* Volume setting title */
"setting_volume" = "Volume";

/* Volume setting help text */
"help_volume" = "Janela do nível de reprodução de áudio. A intensidade é mapeada linearmente entre baixo e alto. A seleção de clips também segue a intensidade — impactos mais ligeiros reproduzem clips mais curtos.";

/* Flash opacity setting title */
"setting_flash_opacity" = "Opacidade do Flash";

/* Flash opacity setting help text */
"help_flash_opacity" = "Janela de brilho do flash do ecrã. O timing do envelope é moldado pela intensidade. Bloqueado dentro da duração do clip de som.";

/* Sensitivity Ruler Labels */

/* Ruler label: hardest impact */
"tier_hard" = "Forte";

/* Ruler label: firm impact */
"tier_firm" = "Firme";

/* Ruler label: medium impact (abbreviated) */
"tier_medium" = "Med";

/* Ruler label: light impact */
"tier_light" = "Leve";

/* Ruler label: lightest impact */
"tier_tap" = "Toque";

/* Sensitivity & Sensors Section */

/* Sensitivity & Sensors accordion title */
"section_sensitivity_sensors" = "Sensibilidade e Sensores";

/* Sensor consensus setting title */
"setting_consensus" = "Consenso de Sensores";

/* Sensor consensus setting help text */
"help_consensus" = "Número de sensores que devem detetar independentemente um impacto antes de acionar. Limitado ao número de sensores que fornecem dados.";

/* Sensor consensus count */
"consensus_format" = "%lld sensores";

/* Cooldown setting title */
"setting_cooldown" = "Tempo de Espera";

/* Cooldown setting help text */
"help_cooldown" = "Tempo mínimo entre reações. 0 = bloqueado apenas pela duração do clip em reprodução.";

/* Accelerometer tuning section header */
"section_accel_tuning" = "Ajuste do Acelerómetro";

/* Frequency band setting title */
"setting_frequency_band" = "Banda de Frequência";

/* Frequency band setting help text */
"help_frequency_band" = "Filtro passa-banda nos dados brutos do acelerómetro. Baixo = corte passa-alta (rejeita vibrações do chão). Alto = corte passa-baixa (rejeita ruído eletrónico).";

/* Spike threshold setting title */
"setting_spike_threshold" = "Limiar de Pico";

/* Spike threshold setting help text */
"help_spike_threshold" = "Magnitude filtrada mínima (força g) para ser considerada como impacto potencial. Aplicado após filtragem passa-banda. Valores mais altos requerem força maior.";

/* Crest factor setting title */
"setting_crest_factor" = "Fator de Crista";

/* Crest factor setting help text */
"help_crest_factor" = "O sinal de pico deve exceder o RMS de fundo por este múltiplo. Pancadas nítidas na secretária disparam bem acima do fundo. Passos elevam o fundo junto com o pico. Valores mais altos rejeitam mais vibração ambiente.";

/* Rise rate setting title */
"setting_rise_rate" = "Taxa de Subida";

/* Rise rate setting help text */
"help_rise_rate" = "Aumento mínimo de magnitude entre amostras consecutivas. Impactos diretos sobem em 1-2 amostras. Vibrações transmitidas sobem gradualmente. Valores mais altos rejeitam vibração indireta.";

/* Confirmations setting title */
"setting_confirmations" = "Confirmações";

/* Confirmations setting help text */
"help_confirmations" = "Amostras acima do limiar necessárias na janela de deteção de 120ms. Golpes diretos produzem 3-5 amostras altas. Sacudidelas únicas produzem 1-2.";

/* Confirmation hit count */
"confirmations_format" = "%lld golpes";

/* Warmup setting title */
"setting_warmup" = "Aquecimento";

/* Warmup setting help text */
"help_warmup" = "Amostras antes da deteção ser ativada. Os filtros precisam de tempo para se estabilizar. A 50 Hz, 50 amostras = 1 segundo.";

/* Report interval setting title */
"setting_report_interval" = "Intervalo de Relatório";

/* Report interval setting help text */
"help_report_interval" = "Intervalo de polling do acelerómetro. 10ms = 100 Hz (predefinição), 5ms = 200 Hz, 20ms = 50 Hz.";


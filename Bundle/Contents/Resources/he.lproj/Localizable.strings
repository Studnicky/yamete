/* Yamete — Hebrew Localizable Strings */

/* Header Section */

/* Daily impact counter */
"impacts_today" = "%lld פגיעות היום";

/* Last impact tier label */
"last_impact" = "אחרון: %@";

/* Detection paused indicator */
"status_paused" = "מושהה";

/* Basic Settings Section */

/* Reactivity setting title */
"setting_reactivity" = "תגובתיות";

/* Reactivity setting help text */
"help_reactivity" = "חלון תגובה לעוצמת הפגיעה. המחוון התחתון = עוצמה מינימלית להפעלה. המחוון העליון = עוצמה לתגובה מקסימלית. ערכים גבוהים יותר מגיבים לפגיעות קלות יותר.";

/* Volume setting title */
"setting_volume" = "עוצמת שמע";

/* Volume setting help text */
"help_volume" = "חלון רמת ניגון השמע. העוצמה ממופה בצורה לינארית בין נמוך לגבוה. בחירת הקליפ גם כן עוקבת אחר העוצמה — פגיעות קלות מנגנות קליפים קצרים יותר.";

/* Flash opacity setting title */
"setting_flash_opacity" = "אטימות ההבזק";

/* Flash opacity setting help text */
"help_flash_opacity" = "חלון בהירות הבזק המסך. תזמון מעטפת מעוצב על ידי העוצמה. מוגבל בתוך משך קליפ הצליל.";

/* Sensitivity Ruler Labels */

/* Ruler label: hardest impact */
"tier_hard" = "חזקה";

/* Ruler label: firm impact */
"tier_firm" = "יציבה";

/* Ruler label: medium impact (abbreviated) */
"tier_medium" = "בינונית";

/* Ruler label: light impact */
"tier_light" = "קלה";

/* Ruler label: lightest impact */
"tier_tap" = "הקשה";

/* Sensitivity & Sensors Section */

/* Sensitivity & Sensors accordion title */
"section_sensitivity_sensors" = "רגישות וחיישנים";

/* Sensor consensus setting title */
"setting_consensus" = "הסכמת חיישנים";

/* Sensor consensus setting help text */
"help_consensus" = "מספר החיישנים שצריכים לזהות פגיעה באופן עצמאי לפני הפעלה. מוגבל למספר החיישנים המספקים נתונים.";

/* Sensor consensus count */
"consensus_format" = "%lld חיישנים";

/* Cooldown setting title */
"setting_cooldown" = "זמן התאוששות";

/* Cooldown setting help text */
"help_cooldown" = "זמן מינימלי בין תגובות. 0 = מוגבל רק על ידי משך הקליפ המתנגן.";

/* Accelerometer tuning section header */
"section_accel_tuning" = "כיוון מד התאוצה";

/* Frequency band setting title */
"setting_frequency_band" = "רצועת תדר";

/* Frequency band setting help text */
"help_frequency_band" = "מסנן מעבר רצועה על נתוני מד התאוצה הגולמיים. נמוך = חיתוך גבוה-תדר (דוחה רעידות רצפה). גבוה = חיתוך נמוך-תדר (דוחה רעש אלקטרוני).";

/* Spike threshold setting title */
"setting_spike_threshold" = "סף ספייק";

/* Spike threshold setting help text */
"help_spike_threshold" = "גודל מינימלי מסונן (כוח g) לצורך שקילה כפגיעה פוטנציאלית. מוחל לאחר סינון הרצועה. ערכים גבוהים יותר דורשים כוח גדול יותר.";

/* Crest factor setting title */
"setting_crest_factor" = "Crest Factor";

/* Crest factor setting help text */
"help_crest_factor" = "אות השיא חייב לחרוג מ-RMS הרקע בכפולה זו. הקשות חדות על השולחן מזנקות הרבה מעל הרקע. צעדים מעלים את הרקע יחד עם השיא. ערכים גבוהים יותר דוחים יותר רטט סביבתי.";

/* Rise rate setting title */
"setting_rise_rate" = "Rise Rate";

/* Rise rate setting help text */
"help_rise_rate" = "עלייה מינימלית בגודל בין דגימות עוקבות. פגיעות ישירות עולות ב-1-2 דגימות. רטט מועבר עולה בהדרגה. ערכים גבוהים יותר דוחים רטט עקיף.";

/* Confirmations setting title */
"setting_confirmations" = "אישורים";

/* Confirmations setting help text */
"help_confirmations" = "דגימות מעל הסף הנדרשות בחלון הזיהוי של 120ms. פגיעות ישירות מייצרות 3-5 דגימות גבוהות. זעזועים בודדים מייצרים 1-2.";

/* Confirmation hit count */
"confirmations_format" = "%lld פגיעות";

/* Warmup setting title */
"setting_warmup" = "חימום";

/* Warmup setting help text */
"help_warmup" = "דגימות לפני הפעלת הזיהוי. המסננים צריכים זמן להתייצב. ב-50 Hz, 50 דגימות = 1 שנייה.";

/* Report interval setting title */
"setting_report_interval" = "מרווח דיווח";

/* Report interval setting help text */
"help_report_interval" = "מרווח סקירת מד התאוצה. 10ms = 100 Hz (ברירת מחדל), 5ms = 200 Hz, 20ms = 50 Hz.";

